<Window x:Class="AgroInvestApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Агроинвест - Учёт техники и заказов" Height="600" Width="1000"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <TextBlock Text="ООО &quot;Башкир-Агроинвест&quot;" FontSize="18" FontWeight="Bold"
                   HorizontalAlignment="Center" Margin="5"/>
        <TabControl Grid.Row="1">
            <!-- ========== КЛИЕНТЫ ========== -->
            <TabItem Header="Клиенты">
                <Grid Margin="5">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <DataGrid x:Name="dgClients" AutoGenerateColumns="True" IsReadOnly="False"
                              SelectionMode="Single" SelectionUnit="FullRow" Grid.Row="0"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="5" Grid.Row="1">
                        <Button x:Name="btnAddClient" Content="Добавить" Width="100" Margin="5" Click="BtnAddClient_Click"/>
                        <Button x:Name="btnEditClient" Content="Редактировать" Width="100" Margin="5" Click="BtnEditClient_Click"/>
                        <Button x:Name="btnDeleteClient" Content="Удалить" Width="100" Margin="5" Click="BtnDeleteClient_Click"/>
                        <Button x:Name="btnRefreshClients" Content="Обновить" Width="100" Margin="5" Click="BtnRefreshClients_Click"/>
                    </StackPanel>
                </Grid>
            </TabItem>

            <!-- ========== ТРАНСПОРТ ========== -->
            <TabItem Header="Транспорт">
                <Grid Margin="5">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <DataGrid x:Name="dgTransport" AutoGenerateColumns="True" IsReadOnly="False"
                              SelectionMode="Single" SelectionUnit="FullRow" Grid.Row="0"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="5" Grid.Row="1">
                        <Button x:Name="btnAddTransport" Content="Добавить" Width="100" Margin="5" Click="BtnAddTransport_Click"/>
                        <Button x:Name="btnEditTransport" Content="Редактировать" Width="100" Margin="5" Click="BtnEditTransport_Click"/>
                        <Button x:Name="btnDeleteTransport" Content="Удалить" Width="100" Margin="5" Click="BtnDeleteTransport_Click"/>
                        <Button x:Name="btnRefreshTransport" Content="Обновить" Width="100" Margin="5" Click="BtnRefreshTransport_Click"/>
                    </StackPanel>
                </Grid>
            </TabItem>

            <!-- ========== ЗАКАЗЫ ========== -->
            <TabItem Header="Заказы">
                <Grid Margin="5">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <DataGrid x:Name="dgOrders" AutoGenerateColumns="True" IsReadOnly="True"
                              SelectionMode="Single" SelectionUnit="FullRow" Grid.Row="0"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="5" Grid.Row="1">
                        <Button x:Name="btnAddOrder" Content="Добавить" Width="100" Margin="5" Click="BtnAddOrder_Click"/>
                        <Button x:Name="btnEditOrder" Content="Редактировать" Width="100" Margin="5" Click="BtnEditOrder_Click"/>
                        <Button x:Name="btnDeleteOrder" Content="Удалить" Width="100" Margin="5" Click="BtnDeleteOrder_Click"/>
                        <Button x:Name="btnRefreshOrders" Content="Обновить" Width="100" Margin="5" Click="BtnRefreshOrders_Click"/>
                    </StackPanel>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</Window>